{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sageport",
  "version": "2.1.2",
  "identifier": "com.joygqz.sageport",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sageport",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "appimage", "deb"],
    "createUpdaterArtifacts": true,
    "publisher": "Quincy Zhang",
    "copyright": "Copyright © 2026 Quincy Zhang",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGQjU3OUU2NzUxOTlGREIKUldUYm54bDE1bm0xNzg1T1REcFZwRFl4a1l2OXNCSnRWazVRLzRMazVoMG9MbW1ydkRoSXp4dE8K",
      "endpoints": [
        "https://github.com/joygqz/sageport/releases/latest/download/latest.json"
      ]
    }
  }
}
